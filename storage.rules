rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Validate media files (Size < 50MB, Image or Video type)
    function isValidMediaFile(resource) {
      return resource.size < 50 * 1024 * 1024
          && (resource.contentType.matches('image/.*') || resource.contentType.matches('video/.*'));
    }

    // ========================================
    // RECIPE IMAGES
    // ========================================
    match /img/recipes/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAuthenticated() && isValidMediaFile(request.resource);
      allow delete: if isAuthenticated();
    }

    // ========================================
    // USER AVATARS
    // ========================================
    match /Avatars/{allPaths=**} {
      allow read: if true;
    }

    // ========================================
    // PENDING IMAGE SUGGESTIONS
    // ========================================
    match /pendingImages/{allPaths=**} {
      allow read: if true;
      allow create: if isAuthenticated()
                     && request.resource.size < 5 * 1024 * 1024
                     && request.resource.contentType.matches('image/.*');
      // Restrict delete/update to Manager (Specific UID for now as fallback, or open to Manager context if Custom Claims were used)
      // Keeping the existing hardcoded UID for backward compatibility if needed, but 'isAuthenticated' is safer than open.
      allow delete, update: if request.auth.uid == "VVEha9tUvnO3oTQTaBtbeusIGnx2";
    }

    // ========================================
    // Grandmother's Cookbook
    // ========================================
    match /grandmas_cookbook/{allPaths=**} {
      allow read: if isAuthenticated();
    }

    // ========================================
    // MEDIA INSTRUCTIONS
    // ========================================
    match /recipes/{recipeId}/media-instructions/{fileName} {
      allow read: if true;
      allow create, update: if isAuthenticated() && isValidMediaFile(request.resource);
      allow delete: if isAuthenticated();
    }
  }
}